# Finnhub API key (company profile/fundamentals data)
FINNHUB_API_KEY=

# Twelve Data API key (historical stock price / OHLCV data)
TWELVEDATA_API_KEY=

# NewsAPI.org API key (news articles)
NEWSAPI_API_KEY=

# override the default HTTP request timeout (seconds)
REQUEST_TIMEOUT_SECONDS=30


# PostgreSQL connection settings (local install)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smartstock
POSTGRES_USER=postgres
POSTGRES_PASSWORD=xxxxxxxxxxx